<!DOCTYPE html>
<html>
<head>
    <title>My Recipe Website</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #fff8f0;
            margin: 0;
            padding: 0;
        }

        header {
            background-color: purple;
            color: white;
            text-align: center;
            padding: 20px;
        }

        section {
            margin: 20px;
            padding: 15px;
            background-color: white;
            border-radius: 10px;
            box-shadow: 0 0 5px gray;
        }

        h2 {
            color: purple;
        }
  
       img{
           width:250px;
           border-radius:10px;
           display:block;
           margin:auto;
       }

       footer {
            text-align: center;
            background-color: purple;
            color: white;
            padding: 10px;
        }
    </style>
</head>

<body>

<header>
    <h1>My Recipe Website</h1>
    <p>Delicious Recipes for Everyone</p>
</header>

<section>
    <h2>🍳 Breakfast</h2>

    <img src="idli.jpg" alt="Idli"
    width="250">

    <ul>
        <li>Idli</li>
        <li>Dosa</li>
        <li>Pongal</li>
    </ul>
</section>
<section>
    <h2>🍛 Lunch</h2>
    <img src="lunch.jpg" alt="Lunch"
    width="250">

    <ul>
        <li>Sambar Rice</li>
        <li>Lemon Rice</li>
        <li>Curd Rice</li>
    </ul>
</section>

<section>
    <h2>🍽 Dinner</h2>
    <img src="dinner.jpg"
    alt="Dinner" width="250">

    <ul>
        <li>Chapati</li>
        <li>Parotta</li>
        <li>Veg Fried Rice</li>
    </ul>
</section>

<section>
    <h2>🥗 Healthy Recipes</h2>
    <img src="healthy.jpg" alt="Healthy
    Food" width="250">
 
    <ul>
        <li>Fruit Salad</li>
        <li>Vegetable Soup</li>
        <li>Sprouts Salad</li>
    </ul>
</section>

<footer>
    <p>© 2026 My Recipe Website</p>
</footer>

</body>
</html>